{
  "name": "studiopod-design",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "package:build": "cd packages/design-system && tsup",
    "package:typecheck": "tsc --noEmit -p packages/design-system/tsconfig.json",
    "package:api-check": "node packages/design-system/scripts/check-api.mjs",
    "package:css-check": "node packages/design-system/scripts/check-css.mjs",
    "package:use-client-check": "node packages/design-system/scripts/check-use-client.mjs",
    "package:pack": "npm pack ./packages/design-system --pack-destination ./packages/design-system",
    "package:inspect": "tar -tzf packages/design-system/studiopod-design-system-*.tgz"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-core": "^4.12.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
