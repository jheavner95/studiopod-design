{
  "name": "@studiopod/design-system",
  "version": "0.10.0",
  "description": "StudioPOD's shared design system: tokens, UI/layout/form/feedback/navigation/overlay/table/metadata primitives, motion and illustration engines, and marketing compositions, for the Web and App products.",
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jheavner95/studiopod-design.git",
    "directory": "packages/design-system"
  },
  "homepage": "https://github.com/jheavner95/studiopod-design/tree/main/packages/design-system#readme",
  "bugs": {
    "url": "https://github.com/jheavner95/studiopod-design/issues"
  },
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "API.md",
    "VERSIONING.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./marketing": {
      "types": "./dist/marketing.d.ts",
      "import": "./dist/marketing.js"
    },
    "./illustrations": {
      "types": "./dist/illustrations.d.ts",
      "import": "./dist/illustrations.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsup --config ./tsup.config.ts",
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "api-check": "node ./scripts/check-api.mjs",
    "exports-check": "node ./scripts/check-exports.mjs",
    "verify": "npm run build && npm run typecheck && npm run api-check && npm run css-check && npm run use-client-check && npm run exports-check",
    "prepublishOnly": "npm run verify",
    "css-check": "node ./scripts/check-css.mjs",
    "use-client-check": "node ./scripts/check-use-client.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "next": ">=14.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "lucide-react": "^1.23.0",
    "framer-motion": "^12.42.2"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
